<Window x:Class="SSStap.Dialogs.AddFromLinkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add from Link" Height="480" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Paste ss:// or ssr:// link:" Grid.Row="0" Margin="0,0,0,4"/>
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="LinkBox" Grid.Column="0" Padding="8,6" VerticalContentAlignment="Center"/>
            <Button Grid.Column="1" Content="Parse" Margin="8,0,0,0" Padding="12,6" Click="Parse_Click"/>
        </Grid>

        <TextBlock Text="Server:" Grid.Row="2" Margin="0,8,0,4"/>
        <TextBox x:Name="ServerBox" Grid.Row="3" Margin="0,0,0,8" Padding="8,6"/>

        <TextBlock Text="Port:" Grid.Row="4" Margin="0,0,0,4"/>
        <TextBox x:Name="PortBox" Grid.Row="5" Margin="0,0,0,8" Padding="8,6"/>

        <TextBlock Text="Password:" Grid.Row="6" Margin="0,0,0,4"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="7" Margin="0,0,0,8" Padding="8,6"/>

        <TextBlock Text="Method:" Grid.Row="8" Margin="0,0,0,4"/>
        <TextBox x:Name="MethodBox" Grid.Row="9" Margin="0,0,0,8" Padding="8,6"/>

        <TextBlock Text="Remarks:" Grid.Row="10" Margin="0,0,0,4"/>
        <TextBox x:Name="RemarksBox" Grid.Row="11" Margin="0,0,0,8" Padding="8,6"/>

        <TextBlock Text="Group:" Grid.Row="12" Margin="0,0,0,4"/>
        <TextBox x:Name="GroupBox" Grid.Row="13" Margin="0,0,0,8" Padding="8,6" Text="Default Group"/>

        <StackPanel Grid.Row="14" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Add" Width="80" Padding="8,6" Margin="0,0,8,0" IsDefault="True" Click="Add_Click"/>
            <Button Content="Cancel" Width="80" Padding="8,6" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
