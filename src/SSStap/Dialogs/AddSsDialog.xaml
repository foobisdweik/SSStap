<Window x:Class="SSStap.Dialogs.AddSsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add SS/SSR Proxy" Height="420" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Server:" Grid.Row="0" Margin="0,0,0,4"/>
        <TextBox x:Name="ServerBox" Grid.Row="1" Margin="0,0,0,12" Padding="8,6"/>

        <TextBlock Text="Port:" Grid.Row="2" Margin="0,0,0,4"/>
        <TextBox x:Name="PortBox" Grid.Row="3" Margin="0,0,0,12" Padding="8,6"/>

        <TextBlock Text="Password:" Grid.Row="4" Margin="0,0,0,4"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="5" Margin="0,0,0,12" Padding="8,6"/>

        <TextBlock Text="Method:" Grid.Row="6" Margin="0,0,0,4"/>
        <ComboBox x:Name="MethodCombo" Grid.Row="7" Margin="0,0,0,12" Padding="8,6" IsEditable="True"
                  Text="aes-256-gcm">
            <ComboBoxItem Content="none"/>
            <ComboBoxItem Content="aes-128-gcm"/>
            <ComboBoxItem Content="aes-256-gcm"/>
            <ComboBoxItem Content="chacha20-ietf-poly1305"/>
            <ComboBoxItem Content="2022-blake3-aes-256-gcm"/>
        </ComboBox>

        <TextBlock Text="Remarks:" Grid.Row="8" Margin="0,0,0,4"/>
        <TextBox x:Name="RemarksBox" Grid.Row="9" Margin="0,0,0,12" Padding="8,6"/>

        <TextBlock Text="Group:" Grid.Row="10" Margin="0,0,0,4"/>
        <TextBox x:Name="GroupBox" Grid.Row="11" Margin="0,0,0,12" Padding="8,6" Text="Default Group"/>

        <StackPanel Grid.Row="14" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Add" Width="80" Padding="8,6" Margin="0,0,8,0" IsDefault="True" Click="Add_Click"/>
            <Button Content="Cancel" Width="80" Padding="8,6" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
